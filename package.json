{
  "name": "synergismofficial",
  "version": "4.1.1",
  "description": "",
  "main": "dist/bundle.js",
  "engines": {
    "node": ">=22.21.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capgo/capacitor-app-attest": "^8.1.14",
    "@capgo/capacitor-keep-awake": "^8.1.15",
    "@capgo/capacitor-updater": "^8.50.2",
    "@paypal/paypal-js": "^8.2.0",
    "@ungap/custom-elements": "^1.3.0",
    "break_infinity.js": "^2.0.0",
    "capacitor-plugin-cdv-purchase": "^13.15.3",
    "clipboard": "^2.0.11",
    "cookie": "^1.1.1",
    "discord-rpc": "^4.0.1",
    "dompurify": "^3.2.7",
    "electron-store": "^11.0.2",
    "electron-window-state": "^5.0.3",
    "fast-mersenne-twister": "^1.0.3",
    "i18next": "^22.4.9",
    "lz-string": "^1.4.4",
    "mime-types": "^3.0.2",
    "rfdc": "^1.4.1",
    "steamworks.js": "^0.4.0",
    "synergism-websocket": "file:./src/mobile/websocket-plugin",
    "worker-timers": "^7.0.53",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@types/cloudflare-turnstile": "^0.2.2",
    "@types/conf": "^2.1.0",
    "@types/discord-rpc": "^4.0.10",
    "@types/lodash.clonedeepwith": "^4.5.9",
    "@types/lz-string": "^1.3.34",
    "@types/mime-types": "^3.0.1",
    "concurrently": "^9.2.1",
    "deep-object-diff": "^1.1.9",
    "dprint": "^0.48.0",
    "electron": "^39.2.7",
    "electron-builder": "26.0.12",
    "esbuild": "^0.25.5",
    "htmlhint": "^1.1.4",
    "husky": "^8.0.3",
    "msw": "2.7.5",
    "oxlint": "^1.53.0",
    "oxlint-tsgolint": "^0.16.0",
    "shx": "^0.4.0",
    "stylelint": "^14.8.2",
    "stylelint-config-standard": "^25.0.0",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "live-server": "npx live-server --port=3000 -q --watch=dist,index.html,Synergism.css,translations",
    "dev": "concurrently \"npm run watch:esbuild\" \"npm run live-server\"",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "npx dprint fmt",
    "format": "npx dprint fmt",
    "csslint": "npx stylelint Synergism.css",
    "csslint:fix": "npx stylelint Synergism.css --fix",
    "htmllint": "npx htmlhint index.html",
    "build:esbuild": "node scripts/build-esbuild.mjs",
    "watch:esbuild": "node --run msw:init && node scripts/build-esbuild.mjs --dev --watch --sourcemap",
    "check:tsc": "npx -p typescript tsc",
    "watch:tsc": "npx -p typescript tsc --watch",
    "prepare": "husky install",
    "cloudflare:build": "node scripts/needsBundling.js || npm run build:esbuild",
    "msw:init": "npx -y msw init . --save",
    "check-circular": "madge --circular src/",
    "electron:cp": "shx rm -rf ./dist && shx mkdir dist && shx cp -r Pictures dist/ && shx cp -r translations dist/ && shx cp index.html Synergism.css favicon.ico dist/",
    "electron:build:assets": "npm run electron:cp && npm run build:esbuild -- --platform=steam --outfile=\"./dist/dist/out.js\"",
    "electron:watch": "node scripts/build-esbuild.mjs --platform=steam --outfile=\"./dist/dist/out.js\" --dev --watch --sourcemap --no-minify",
    "electron:dev": "npm run electron:cp && npm run build:esbuild -- --platform=steam --outfile=\"./dist/dist/out.js\" && npx -y msw init dist --save && electron electron/main.ts",
    "electron:build": "npm run electron:build:assets && electron-builder --win --mac --linux",
    "electron:build:win": "npm run electron:build:assets && electron-builder --win",
    "electron:build:mac": "npm run electron:build:assets && electron-builder --mac",
    "electron:build:linux": "npm run electron:build:assets && electron-builder --linux",
    "cap:build": "npm run build:esbuild -- --platform=mobile --outfile=\"./dist/dist/out.js\"",
    "cap:sync": "npm run electron:cp && npm run cap:build && npx cap sync",
    "cap:ios:open": "npx cap open ios",
    "cap:android:open": "npx cap open android"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pseudo-Corp/SynergismOfficial.git"
  },
  "keywords": [
    "synergism",
    "synergismofficial"
  ],
  "author": "Platonic (Kevin Bunn)",
  "maintainers": [
    {
      "email": "pseudonian@gmail.com",
      "name": "Kevin Bunn"
    },
    {
      "email": "maitken033380023@gmail.com",
      "name": "Matthew Aitken"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Pseudo-Corp/SynergismOfficial/issues"
  },
  "homepage": "https://github.com/Pseudo-Corp/SynergismOfficial#readme",
  "msw": {
    "workerDirectory": [
      ".",
      "",
      "dist"
    ]
  }
}
